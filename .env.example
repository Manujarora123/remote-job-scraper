# LinkedIn session cookie (grab from browser DevTools → Application → Cookies → li_at)
LINKEDIN_LI_AT=

# Optional: Naukri credentials for API access
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# Telegram notifications (reuse from eauctions-scraper if set up)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Issue #2 scaffold toggles (permissive defaults)
ELIGIBILITY_SCORING_ENABLED=true
ELIGIBILITY_POLICY=pass_through
ELIGIBILITY_DEFAULT_SCORE=1.0

# Issue #23 verification + compliance
EMAIL_VERIFY_PROVIDER=neverbounce
NEVERBOUNCE_API_KEY=
ZEROBOUNCE_API_KEY=
VERIFY_MX_PRECHECK=true
VERIFY_CATCHALL_PRECHECK=true
MAX_TOUCHES_PER_CONTACT=3
SEND_WINDOW_START=09:00
SEND_WINDOW_END=18:00
SUPPRESSION_FILE=output/suppression_list.txt
COMPLIANCE_AUDIT_LOG=logs/compliance_audit.log
