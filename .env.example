# LinkedIn session cookie (grab from browser DevTools → Application → Cookies → li_at)
LINKEDIN_LI_AT=

# Optional: Naukri credentials for API access
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# Telegram notifications (reuse from eauctions-scraper if set up)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Issue #2 scaffold toggles (permissive defaults)
ELIGIBILITY_SCORING_ENABLED=true
ELIGIBILITY_POLICY=pass_through
ELIGIBILITY_DEFAULT_SCORE=1.0
