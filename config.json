{
  "job_types": ["customer success", "business development", "BD", "account manager", "sales"],
  "locations": ["India", "Remote", "Bangalore", "Hyderabad", "Mumbai", "Delhi"],
  "sources": {
    "linkedin": {
      "enabled": false,
      "note": "Requires auth"
    },
    "indeed": {
      "enabled": true,
      "base_url": "https://www.indeed.com/jobs"
    },
    "remote_ok": {
      "enabled": true,
      "base_url": "https://remoteok.com/remote-jobs",
      "api": "https://remoteok.com/api"
    },
    "we_work_remotely": {
      "enabled": true,
      "base_url": "https://weworkremotely.com/remote-jobs"
    },
    "naukri": {
      "enabled": true,
      "base_url": "https://www.naukri.com/jobs-in-india",
      "note": "Requires Selenium"
    },
    "remotive": {
      "enabled": true,
      "base_url": "https://remotive.com/api/remote-jobs",
      "categories": ["sales", "customer-service", "business"]
    },
    "wellfound": {
      "enabled": false,
      "base_url": "https://wellfound.com/jobs"
    },
    "glassdoor": {
      "enabled": false,
      "base_url": "https://www.glassdoor.com"
    },
    "google_alerts": {
      "enabled": true,
      "note": "Uses Gmail API to read Google Alert emails"
    }
  },
  "scrape_interval_hours": 3,
  "output_dir": "output",
  "dedupe": true
}
